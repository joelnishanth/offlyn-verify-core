graph TB
    subgraph "Untrusted Domain"
        PLANNER["AI Planner<br/>(LLM / Agentic System)"]
    end

    subgraph "Actuation Boundary"
        GATE["Verify Core Gate<br/>(ABEP)"]
        POLICY["Signed Policy<br/>Capsule"]
        REPLAY["Replay Cache"]
        AUDIT["Audit Log<br/>(append-only)"]
    end

    subgraph "Trusted Domain"
        ACTUATOR["Robot Actuator"]
    end

    PLANNER -->|"action request"| GATE
    POLICY -->|"signed rules"| GATE
    GATE -->|"ALLOW + auth token"| ACTUATOR
    GATE -->|"DENY"| PLANNER
    GATE --> REPLAY
    GATE --> AUDIT
    PLANNER -.->|"❌ direct bypass blocked"| ACTUATOR

    style GATE fill:#e74c3c,stroke:#c0392b,color:#fff
    style POLICY fill:#2ecc71,stroke:#27ae60,color:#fff
    style ACTUATOR fill:#3498db,stroke:#2980b9,color:#fff
    style PLANNER fill:#f39c12,stroke:#e67e22,color:#fff
    style REPLAY fill:#9b59b6,stroke:#8e44ad,color:#fff
    style AUDIT fill:#1abc9c,stroke:#16a085,color:#fff
